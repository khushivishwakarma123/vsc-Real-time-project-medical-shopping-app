<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Internet permission -->
    <uses-permission android:name="android.permission.INTERNET" />

    <application
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:theme="@style/Theme.ClothesShopApp">
        <activity
            android:name=".OrderSuccessActivity"
            android:exported="false" />
        <activity
            android:name=".PaymentActivity"
            android:exported="false" />
        <activity
            android:name=".CheckoutActivity"
            android:exported="false" />
        <activity
            android:name=".CartAdapter"
            android:exported="false" /> <!-- ✅ LOGIN (START SCREEN) -->
        <activity
            android:name=".LoginActivity"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />

                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity> <!-- ✅ SIGNUP -->
        <activity
            android:name=".SignupActivity"
            android:exported="false" /> <!-- ✅ HOME -->
        <activity
            android:name=".MainActivity"
            android:exported="false" /> <!-- ✅ PRODUCT DETAILS -->
        <activity
            android:name=".ProductDetailsActivity"
            android:exported="false" /> <!-- ✅ CART -->
        <activity
            android:name=".CartActivity"
            android:exported="false" />
    </application>

</manifest>